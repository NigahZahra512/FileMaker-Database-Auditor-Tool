# Copy this file to .env and fill in ONE provider's key.
# (Not required to run the app at all -- you can also paste a key into
#  the app's Settings panel in the browser instead.)

AI_PROVIDER=gemini

# Fill in only the key for the provider you set above.
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
GROQ_API_KEY=
